    class PlanetWeatherScraper:
        def __init__(self, planet):
            self.planet = planet
            self.weather_data = {}

        def scrape_weather_data(self):
            url = f"https://www.planetweather.com/{self.planet}"
            response = requests.get(url)
            soup = BeautifulSoup(response.text, 'html.parser')
            weather_info = soup.find('div', class_='weather-info')
            self.weather_data[self.planet] = weather_info.text
            print(f"Weather data scraped for {self.planet}: {self.weather_data[self.planet]}")

    class ExoplanetWeatherScraper:
        def __init__(self, exoplanet):
            self.exoplanet = exoplanet
            self.weather_data = {}

        def scrape_weather_data(self):
            url = f"https://www.exoplanetweather.com/{self.exoplanet}"
            response = requests.get(url)
            soup = BeautifulSoup(response.text, 'html.parser')
            weather_info = soup.find('div', class_='weather-info')
            self.weather_data[self.exoplanet] = weather_info.text
            print(f"Weather data scraped for {self.exoplanet}: {self.weather_data[self.exoplanet]}")

    # Example usage
    earth_weather_scraper = PlanetWeatherScraper("Earth")
    earth_weather_scraper.scrape_weather_data()

    exoplanet_weather_scraper = ExoplanetWeatherScraper("Proxima Centauri b")
    exoplanet_weather_scraper.scrape_weather_data()

