// Function to generate a random key for encryption
std::string generateRandomKey(int keyLength) {
    std::string characters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890";
    std::random_device rd;
    std::mt19937 mt(rd());
    std::uniform_int_distribution<int> dist(1, characters.size() - 1);
    std::string key;
    for (int i = 0; i < keyLength; ++i) {
        key += characters[dist(mt)];
    }
    return key;
}

