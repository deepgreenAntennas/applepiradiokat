        self.safe = True
        print(f"{self.name} is now safe.")

class ApplePiRadioCat(Cat):
    def __init__(self, name, kittens):
        super().__init__(name)
        self.kittens = kittens

    def move_kittens(self, new_location):
        for kitten in self.kittens:
            kitten.move_to_safe_place(new_location)
        self.move_to_safe_place(new_location)

    def respond(self):
        print(f"{self.name} is responding...")

    def predatory_breadth(self):
        print(f"{self.name} is demonstrating predatory breadth...")

