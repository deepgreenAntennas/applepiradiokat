from qiskit import QuantumCircuit, Aer, execute
from qiskit.visualization import plot_histogram

# Create a Quantum Circuit
qc = QuantumCircuit(4, 4)

# Apply Hadamard gates to all qubits
for qubit in range(4):
    qc.h(qubit)

# Measure all qubits
for qubit in range(4):
    qc.measure(qubit, qubit)

# Simulate the circuit
backend = Aer.get_backend('qasm_simulator')
job = execute(qc, backend, shots=1000)
result = job.result()
counts = result.get_counts()

# Plot the results
plot_histogram(counts)
# Define the number of qubits
num_qubits = 48000208

# Create a Quantum Circuit with the specified number of qubits
qc_large = QuantumCircuit(num_qubits, num_qubits)

# Apply Hadamard gates to all qubits in the lattice
for qubit in range(num_qubits):
    qc_large.h(qubit)

# Measure all qubits in the lattice
for qubit in range(num_qubits):
    qc_large.measure(qubit, qubit)

# Simulate the circuit
backend_large = Aer.get_backend('qasm_simulator')
job_large = execute(qc_large, backend_large, shots=1000)
result_large = job_large.result()
counts_large = result_large.get_counts()

# Plot the results
plot_histogram(counts_large)
