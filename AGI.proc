response = requests.get(oec_url)
oec_data = response.json()
for system in oec_data:
    star_database[system["name"]] = {"name": system["name"], "mass": system["star"]["mass"], "radius": system["star"]["radius"]}
    for planet in system["planets"]:
        exoplanet_database[planet["name"]] = {"name": planet["name"], "mass": planet["mass"], "radius": planet["radius"]}

