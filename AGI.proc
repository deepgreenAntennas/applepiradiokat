# Web scraping databases containing information about galaxies, stars, and exoplanets
galaxy_database = {}
star_database = {}
exoplanet_database = {}

# NASA Exoplanet Archive
nasa_url = "https://exoplanetarchive.ipac.caltech.edu/cgi-bin/TblView/nph-tblView?table=exoplanets"
response = requests.get(nasa_url)
soup = BeautifulSoup(response.text, 'html.parser')
tables = soup.find_all('table')
exoplanet_data = []
for table in tables:
    rows = table.find_all('tr')
    for row in rows:
        cols = row.find_all('td')
        cols = [col.text.strip() for col in cols]
        exoplanet_data.append([col for col in cols if col])  # Remove empty columns

# Format outputs for Deep Green projects
for exoplanet in exoplanet_data:
    exoplanet_database[exoplanet[0]] = {"name": exoplanet[1], "mass": exoplanet[2], "radius": exoplanet[3]}

