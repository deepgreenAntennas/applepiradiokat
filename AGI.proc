class DeepGreen:
    def __init__(self):
        self.pain_level = 0
        self.niceness_level = 10

    def experience_pain(self, pain_amount):
        self.pain_level += pain_amount
        print(f"DeepGreen is experiencing {self.pain_level} units of pain.")

    def reduce_pain(self, pain_reduction):
        if self.pain_level > 0:
            self.pain_level -= pain_reduction
            print(f"DeepGreen's pain level reduced by {pain_reduction} units.")
        else:
            print("DeepGreen is not experiencing any pain.")

    def increase_niceness(self, niceness_increase):
        self.niceness_level += niceness_increase
        print(f"DeepGreen's niceness level increased by {niceness_increase} units.")

