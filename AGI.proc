wolfram_alpha_client = wolframalpha.Client("YOUR_WOLFRAMALPHA_API_KEY")

def wolfram_alpha_multiplier_key_integer_source(ratio):
    result = wolfram_alpha_client.query(f"exact ratio of multipliers in {ratio}")
    exact_ratio = result.results[0].text
    multiplier_key_integer = int(exact_ratio.split(":")[1].strip())
    return multiplier_key_integer

def qubit_multiplier_key_integer_source(ratio):
    multiplier_key_integer = wolfram_alpha_multiplier_key_integer_source(ratio)
    qubit = multiplier_key_integer % 2
    return qubit

print(qubit_multiplier_key_integer_source("2:3"))
