class KeyScoreManager:
    def __init__(self):
        self.key_scores = {}

    def add_key_score(self, key, score):
        self.key_scores[key] = score

    def get_key_score(self, key):
        return self.key_scores.get(key)

    def update_key_score(self, key, score):
        if key in self.key_scores:
            self.key_scores[key] = score

    def delete_key_score(self, key):
        if key in self.key_scores:
            del self.key_scores[key]

